# ╔══════════════════════════════════════════════════════════════╗
# ║   Slap Battles Multi Macro — Bot Secrets (Replit)           ║
# ║   Skopiuj do Replit jako Secrets (nie jako plik .env)       ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Discord ──────────────────────────────────────────────────────
# Token bota Discord (Settings → Bot → Token)
DISCORD_TOKEN=your_discord_bot_token_here

# ID kanału, na który bot ma raportować aktywność (opcjonalne)
ADMIN_CHANNEL_ID=123456789012345678

# ── GitHub Gist (przechowywanie licenses.json) ───────────────────
# GitHub Personal Access Token z TYLKO zakresem "gist"
# Utwórz na: github.com/settings/tokens → New classic token → [x] gist
GIST_TOKEN=ghp_your_github_token_with_gist_scope

# ID Gista (hash z URL, np. gist.github.com/user/TUTAJ_JEST_ID)
# Jak stworzyć Gist: patrz README.md → sekcja "Konfiguracja Gist"
GIST_ID=abc123def456your_gist_id_here

# ── Opcjonalne ───────────────────────────────────────────────────
# Sekret webhooka (jeśli używasz własnej weryfikacji webhooków)
# WEBHOOK_SECRET=
